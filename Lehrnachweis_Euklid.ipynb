   "outputs": [],
   "source": [
    "def extended_euclidean_algorithm_modulo(A,B):\n",
    "    ia=A\n",
    "    ib=B\n",
    "    ma=1\n",
    "    na=0\n",
    "    mb=0\n",
    "    nb=1\n",
    "    while (ia > 0 and ib > 0):\n",
    "        if ia > ib:\n",
    "            q  = ia // ib # integer division\n",
    "            ia = ia %  ib \n",
    "            ma = ma - q * mb\n",
    "            na = na - q * nb\n",
    "        else:\n",
    "            q  = ib // ia\n",
    "            ib = ib % ia \n",
    "            mb = mb - q * ma\n",
    "            nb = nb - q * na\n",
    "    if ia == 0:\n",
    "        return ib,mb,nb\n",
    "    if ib == 0:\n",
    "        return ia,ma,na\n",
    "\n",
    "Teste_extended_algorithm(extended_euclidean_algorithm_modulo)"
   ]
