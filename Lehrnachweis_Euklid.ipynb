    "def extended_euclidean_algorithm_subtract(A,B):\n",
    "    ia=A\n",
    "    ib=B\n",
    "    ma=1\n",
    "    na=0\n",
    "    mb=0\n",
    "    nb=1\n",
    "    while (ia > 0 and ib > 0):\n",
    "        if ia > ib:\n",
    "            ia = (ia - ib) \n",
    "            ma=ma-mb\n",
    "            na=na-nb\n",
    "        else:\n",
    "            ib = (ib - ia) \n",
    "            mb=mb-ma\n",
    "            nb=nb-na\n",
    "    if ia == 0:\n",
    "        return ib,mb,nb\n",
    "    if ib == 0:\n",
    "        return ia,ma,na\n",
    "\n",
    "Teste_extended_algorithm(extended_euclidean_algorithm_subtract)  "
   ]
